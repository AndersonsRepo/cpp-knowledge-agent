# === LLM Provider (set ONE) ===
# Anthropic (Claude Sonnet) — recommended
ANTHROPIC_API_KEY=your-api-key-here
# OpenAI (GPT-4o)
OPENAI_API_KEY=your-api-key-here
# OPENAI_MODEL=gpt-4o
# OpenRouter (any model via OpenAI-compatible API)
OPENROUTER_API_KEY=your-api-key-here
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# === Embedding Provider (optional — enables hybrid semantic + keyword search) ===
# Default: ollama (local, free). Set EMBEDDING_PROVIDER to override.
# EMBEDDING_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=nomic-embed-text
# EMBEDDING_PROVIDER=openai
# OPENAI_EMBED_MODEL=text-embedding-3-small
# EMBEDDING_PROVIDER=openrouter
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
